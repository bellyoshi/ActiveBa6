'--------------------------------------------------------
' Time Format(used in MCI_SET_PARAMS, MCI_STATUS_PARAMS)

Const MCI_FORMAT_MILLISECONDS =       0
Const MCI_FORMAT_HMS =                1
Const MCI_FORMAT_MSF =                2
Const MCI_FORMAT_FRAMES =             3
