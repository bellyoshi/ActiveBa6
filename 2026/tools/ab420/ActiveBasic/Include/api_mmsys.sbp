'----------------------------------------------
' String resource number bases (internal use)

Const MMSYSERR_BASE =        0
Const WAVERR_BASE =          32
Const MIDIERR_BASE =         64
Const TIMERR_BASE =          96
Const JOYERR_BASE =          160
Const MCIERR_BASE =          256
Const MIXERR_BASE =          1024

