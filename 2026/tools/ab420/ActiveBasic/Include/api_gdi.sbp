' api_gdi.sbp - Graphics Device Integerface API


Const CLR_INVALID =   &HFFFFFFFF
Const GDI_ERROR =     &HFFFFFFFF


' Point/Rectangle/Size struct
Type POINTAPI
	x As Long
	y As Long
End Type
Type RECT
	left As Long
	top As Long
	right As Long
	bottom As Long
End Type
Type SIZE
	cx As Long
	cy As Long
End Type


Const RGB(r, g, b) = ((r) As Long) Or (((g) As Long) <<8) Or (((b) As Long) <<16)
Type RGBQUAD
	rgbBlue As Byte
	rgbGreen As Byte
	rgbRed As Byte
	rgbReserved As Byte
End Type


