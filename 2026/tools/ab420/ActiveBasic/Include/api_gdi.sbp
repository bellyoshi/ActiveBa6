' Bitmap Header Definition
Type BITMAP
	bmType As Long
	bmWidth As Long
	bmHeight As Long
	bmWidthBytes As Long
	bmPlanes As Integer
	bmBitsPixel As Integer
	bmBits As Long
End Type


' structures for defining DIBs
Const BI_RGB =       0
Const BI_RLE8 =      1
Const BI_RLE4 =      2
Const BI_BITFIELDS = 3
Const BI_JPEG =      4
Const BI_PNG =       5
Type BITMAPINFOHEADER
	biSize As Long
	biWidth As Long
	biHeight As Long
	biPlanes As Integer
	biBitCount As Integer
	biCompression As Long
	biSizeImage As Long
	biXPelsPerMeter As Long
	biYPelsPerMeter As Long
	biClrUsed As Long
	biClrImportant As Long
End Type
Type BITMAPINFO
	bmiHeader As BITMAPINFOHEADER
	bmpColors(255) As RGBQUAD
End Type


' Bitmap file header struct
Type Align(2) BITMAPFILEHEADER
	bfType As Integer
	bfSize As Long
	bfReserved1 As Integer
	bfReserved2 As Integer
	bfOffBits As Long
End Type


