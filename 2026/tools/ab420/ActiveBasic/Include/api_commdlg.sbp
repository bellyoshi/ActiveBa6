Const CC_ENABLETEMPLATE =       &H00000020
Const CC_ENABLETEMPLATEHANDLE = &H00000040
Const CC_SOLIDCOLOR =           &H00000080
Const CC_ANYCOLOR =             &H00000100
Type CHOOSECOLOR
	lStructSize    As DWord
	hwndOwner      As HWND
	hInstance      As HINSTANCE
	rgbResult      As DWord
	lpCustColors   As DWordPtr
	Flags          As DWord
	lCustData      As DWord
	lpfnHook       As VoidPtr
	lpTemplateName As BytePtr
End Type
Declare Function ChooseColor Lib "comdlg32" Alias "ChooseColorA" (ByRef lpcc As CHOOSECOLOR) As Long


