End Type
Declare Function GetOpenFileName Lib "comdlg32" Alias "GetOpenFileNameA" (ByRef lpofn As OPENFILENAME) As Long
Declare Function GetSaveFileName Lib "comdlg32" Alias "GetSaveFileNameA" (ByRef lpofn As OPENFILENAME) As Long
Declare Function GetFileTitle Lib "comdlg32" Alias "GetFileTitleA" (lpszFile As BytePtr, lpszTitle As BytePtr, cbBuf As Integer) As Integer


