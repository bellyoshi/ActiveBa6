'--------------
' Matrix Stack
'--------------
Class ID3DXMatrixStack
	Inherits IUnknown
Public
    'ID3DXMatrixStack methods
	Virtual Function Pop() As DWord
	Virtual Function Push() As DWord
	Virtual Function LoadIdentity() As DWord
	Virtual Function LoadMatrix(pM As *D3DXMATRIX) As DWord
	Virtual Function MultMatrix(pM As *D3DXMATRIX) As DWord
	Virtual Function MultMatrixLocal(pM As *D3DXMATRIX) As DWord
	Virtual Function RotateAxis(pV As *D3DXVECTOR3, Angle As Single) As DWord
	Virtual Function RotateAxisLocal(pV As *D3DXVECTOR3, Angle As Single) As DWord
	Virtual Function RotateYawPitchRoll(Yaw As Single, Pitch As Single, Roll As Single) As DWord
	Virtual Function RotateYawPitchRollLocal(Yaw As Single, Pitch As Single, Roll As Single) As DWord
	Virtual Function Scale(x As Single, y As Single, z As Single) As DWord
	Virtual Function ScaleLocal(x As Single, y As Single, z As Single) As DWord
	Virtual Function Translate(x As Single, y As Single, z As Single) As DWord
	Virtual Function TranslateLocal(x As Single, y As Single, z As Single) As DWord
	Virtual Function GetTop() As *D3DXMATRIX
End Class

Declare Function D3DXCreateMatrixStack Lib "dx9abm" Alias "D3DXCreateMatrixStack_abm" (Flags As DWord, ppStack As **ID3DXMatrixStack) As DWord
