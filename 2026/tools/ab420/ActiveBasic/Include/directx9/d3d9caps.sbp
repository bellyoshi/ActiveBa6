' VertexProcessingCaps
Const D3DVTXPCAPS_TEXGEN                   = &H00000001   'device can do texgen
Const D3DVTXPCAPS_MATERIALSOURCE7          = &H00000002   'device can do DX7-level colormaterialsource ops
