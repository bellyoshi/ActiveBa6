Const D3DPBLENDCAPS_INVDESTALPHA    = &H00000080
Const D3DPBLENDCAPS_DESTCOLOR       = &H00000100
Const D3DPBLENDCAPS_INVDESTCOLOR    = &H00000200
Const D3DPBLENDCAPS_SRCALPHASAT     = &H00000400
