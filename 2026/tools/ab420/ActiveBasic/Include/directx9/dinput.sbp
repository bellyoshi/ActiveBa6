' Mouse
'-----------------------

Type DIMOUSESTATE
	lX As Long
	lY As Long
	lZ As Long
	rgbButtons[3] As Byte
End Type

Type DIMOUSESTATE2
	lX As Long
	lY As Long
	lZ As Long
	rgbButtons[7] As Byte
End Type


Declare Function DirectInput8Create Lib "dinput8" (hinst As HINSTANCE, dwVersion As DWord, ByRef riidltf As GUID, ppvOut As *DWord, punkOuter As *IUnknown) As DWord


'-------------------
