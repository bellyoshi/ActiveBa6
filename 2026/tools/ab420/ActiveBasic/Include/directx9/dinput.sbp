Class IDirectInputEffect
	Inherits IUnknown
Public
	'IDirectInputEffect methods
	Virtual Function Initialize(hinst As HINSTANCE, dwVersion As DWord, ByRef rguid As GUID) As DWord
	Virtual Function GetEffectGuid(pguid As *GUID) As DWord
	Virtual Function GetParameters(peff As LPDIEFFECT, dwFlags As DWord) As DWord
	Virtual Function SetParameters(peff As LPDIEFFECT, dwFlags As DWord) As DWord
	Virtual Function Start(dwIterations As DWord, dwFlags As DWord) As DWord
	Virtual Function Stop() As DWord
	Virtual Function GetEffectStatus(pdwFlags As *DWord) As DWord
	Virtual Function Download() As DWord
	Virtual Function Unload() As DWord
	Virtual Function Escape(pesc As LPDIEFFESCAPE) As DWord
End Class
TypeDef LPDIRECTINPUTEFFECT = *IDirectInputEffect


