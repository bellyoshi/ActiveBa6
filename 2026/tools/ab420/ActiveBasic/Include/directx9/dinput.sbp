Class IDirectInputDevice8
	Inherits IUnknown
Public
	'IDirectInputDevice8 methods
	Virtual Function GetCapabilities(lpDIDevCaps As LPDIDEVCAPS) As DWord
	Virtual Function EnumObjects(lpCallback As VoidPtr, pvRef As VoidPtr, dwFlags As DWord) As DWord
	Virtual Function GetProperty(ByRef rguidProp As GUID, pdiph As LPDIPROPHEADER) As DWord
	Virtual Function SetProperty(ByRef rguidProp As GUID, pdiph As LPDIPROPHEADER) As DWord
	Virtual Function Acquire() As DWord
	Virtual Function Unacquire() As DWord
	Virtual Function GetDeviceState(cbData As DWord, lpvData As VoidPtr) As DWord
	Virtual Function GetDeviceData(cbObjectData As DWord, rgdod As LPDIDEVICEOBJECTDATA, pdwInOut As *DWord, dwFlags As DWord) As DWord
	Virtual Function SetDataFormat(lpdf As LPDIDATAFORMAT) As DWord
	Virtual Function SetEventNotification(hEvent As HANDLE) As DWord
	Virtual Function SetCooperativeLevel(hwnd As HWND, dwFlags As DWord) As DWord
	Virtual Function GetObjectInfo(pdidoi As LPDIDEVICEOBJECTINSTANCE, dwObj As DWord, dwHow As DWord) As DWord
	Virtual Function GetDeviceInfo(pdidi As LPDIDEVICEINSTANCE) As DWord
	Virtual Function RunControlPanel(hwndOwner As HWND, dwFlags As DWord) As DWord
	Virtual Function Initialize(hinst As HINSTANCE, dwVersion As DWord, ByRef rguid As GUID) As DWord
	Virtual Function CreateEffect(ByRef rguid As GUID, lpeff As LPDIEFFECT, ppdeff As *LPDIRECTINPUTEFFECT, punkOuter As LPUNKNOWN) As DWord
	Virtual Function EnumEffects(lpCallback As VoidPtr, pvRef As VoidPtr, dwEffType As DWord) As DWord
	Virtual Function GetEffectInfo(pdei As LPDIEFFECTINFO, ByRef rguid As GUID) As DWord
	Virtual Function GetForceFeedbackState(pdwOut As *DWord) As DWord
	Virtual Function SendForceFeedbackCommand(dwFlags As DWord) As DWord
	Virtual Function EnumCreatedEffectObjects(lpCallback As VoidPtr, pvRef As VoidPtr, fl As DWord) As DWord
	Virtual Function Escape(pesc As LPDIEFFESCAPE) As DWord
	Virtual Function Poll() As DWord
	Virtual Function SendDeviceData(cbObjectData As DWord, rgdod As LPDIDEVICEOBJECTDATA, pdwInOut As *DWord, fl As DWord) As DWord
	Virtual Function EnumEffectsInFile(lpszFileName As *Char, pec As VoidPtr, pvRef As VoidPtr, dwFlags As DWord) As DWord
	Virtual Function WriteEffectToFile(lpszFileName As *Char, dwEntries As DWord, rgDiFileEft As LPDIFILEEFFECT, dwFlags As DWord) As DWord
	Virtual Function BuildActionMap(lpdiaf As LPDIACTIONFORMAT, lpszUserName As *Char, dwFlags As DWord) As DWord
	Virtual Function SetActionMap(lpdiActionFormat As LPDIACTIONFORMAT, lptszUserName As *Char, dwFlags As DWord) As DWord
	Virtual Function GetImageInfo(lpdiDevImageInfoHeader As LPDIDEVICEIMAGEINFOHEADER) As DWord
End Class
TypeDef LPDIRECTINPUTDEVICE8 = *IDirectInputDevice8


Class IDirectInput8
	Inherits IUnknown
Public
	'IDirectInput8 methods
	Virtual Function CreateDevice(ByRef rguid As GUID, lplpDirectInputDevice As *LPDIRECTINPUTDEVICE8, pUnkOuter As LPUNKNOWN) As DWord
	Virtual Function EnumDevices(dwDevType As DWord, lpCallback As VoidPtr, pvRef As VoidPtr, dwFlags As DWord) As DWord
	Virtual Function GetDeviceStatus(ByRef rguidInstance As GUID) As DWord
	Virtual Function RunControlPanel(hwndOwner As HWND, dwFlags As DWord) As DWord
	Virtual Function Initialize(hinst As HINSTANCE, dwVersion As DWord) As DWord
	Virtual Function FindDevice(ByRef rguidClass As GUID, ptszName As *Char, pguidInstance As *GUID) As DWord
	Virtual Function EnumDevicesBySemantics(ptszUserName As *Char, lpdiActionFormat As LPDIACTIONFORMAT, lpCallback As VoidPtr, pvRef As VoidPtr, dwFlags As DWord) As DWord
	Virtual Function ConfigureDevices(lpdiCallback As VoidPtr, lpdiCDParams As LPDICONFIGUREDEVICESPARAMS, dwFlags As DWord, pvRefData As VoidPtr) As DWord
End Class
TypeDef LPDIRECTINPUT8 = *IDirectInput8


