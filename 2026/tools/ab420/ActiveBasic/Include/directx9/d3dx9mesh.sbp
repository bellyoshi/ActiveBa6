	Virtual Function TrimByVertices(NewVerticesMin As DWord, NewVerticesMax As DWord, rgiFaceRemap As DWordPtr, rgiVertRemap As DWord) As DWord
	Virtual Function GetAdjacency(pAdjacency As DWordPtr) As DWord
	Virtual Function GenerateVertexHistory(pVertexHistory As DWordPtr) As DWord
End Class
TypeDef LPD3DXPMESH = *ID3DXPMesh


Class ID3DXSPMesh
	Inherits IUnknown
Public
    'ID3DXSPMesh
	Virtual Function GetNumFaces() As DWord
	Virtual Function GetNumVertices() As DWord
	Virtual Function GetFVF() As DWord
	Virtual Function GetDeclaration(Declaration As *D3DVERTEXELEMENT9) As DWord
	Virtual Function GetOptions() As DWord
	Virtual Function GetDevice(ppDevice As *LPDIRECT3DDEVICE9) As DWord
	Virtual Function CloneMeshFVF(Options As DWord, FVF As DWord, pD3DDevice As LPDIRECT3DDEVICE9, pAdjacencyOut As DWordPtr, pVertexRemapOut As DWordPtr, ppCloneMesh As **ID3DXMesh) As DWord
	Virtual Function CloneMesh(Options As DWord, pDeclaration As *D3DVERTEXELEMENT9, pD3DDevice As LPDIRECT3DDEVICE9, pAdjacencyOut As DWordPtr, pVertexRemapOut As DWordPtr, ppCloneMesh As **ID3DXMesh) As DWord
	Virtual Function ClonePMeshFVF(Options As DWord, FVF As DWord, pD3DDevice As LPDIRECT3DDEVICE9, pVertexRemapOut As DWordPtr, pErrorsByFace As SinglePtr, ppCloneMesh As **ID3DXMesh) As DWord
	Virtual Function ClonePMesh(Options As DWord, pDeclaration As *D3DVERTEXELEMENT9, pD3DDevice As LPDIRECT3DDEVICE9, pVertexRemapOut As DWordPtr, pErrorsbyFace As SinglePtr, ppCloneMesh As **ID3DXMesh) As DWord
	Virtual Function ReduceFaces(Faces As DWord) As DWord
	Virtual Function ReduceVertices(Vertices As DWord) As DWord
	Virtual Function GetMaxFaces() As DWord
	Virtual Function GetMaxVertices() As DWord
	Virtual Function GetVertexAttributeWeights(pVertexAttributeWeights As *D3DXATTRIBUTEWEIGHTS) As DWord
	Virtual Function GetVertexWeights(pVertexWeights As SinglePtr) As DWord
End Class
TypeDef LPD3DXSPMESH = *ID3DXSPMesh


' Subset of the mesh that has the same attribute and bone combination.
' This subset can be rendered in a single draw call
Type D3DXBONECOMBINATION
	AttribId As DWord
	FaceStart As DWord
	FaceCount As DWord
	VertexStart As DWord
	VertexCount As DWord
	BoneId As DWordPtr
End Type

Type D3DXPATCHINFO
	PatchType As D3DXPATCHMESHTYPE
	Degree As D3DDEGREETYPE
	Basis As D3DBASISTYPE
End Type


Class ID3DXPatchMesh
	Inherits IUnknown
Public
	'ID3DXPatchMesh

	'Return creation parameters
	Virtual Function GetNumPatches() As DWord
	Virtual Function GetNumVertices() As DWord
	Virtual Function GetDeclaration(Declaration As *D3DVERTEXELEMENT9) As DWord
	Virtual Function GetControlVerticesPerPatch() As DWord
	Virtual Function GetOptions() As DWord
	Virtual Function GetDevice(ppDevice As *LPDIRECT3DDEVICE9) As DWord
	Virtual Function GetPatchInfo(PatchInfo As *D3DXPATCHINFO) As DWord

	'Control mesh access    
	Virtual Function GetVertexBuffer(ppVB As **IDirect3DVertexBuffer9) As DWord
	Virtual Function GetIndexBuffer(ppIB As **IDirect3DIndexBuffer9) As DWord
	Virtual Function LockVertexBuffer(flags As DWord, ppData As DWordPtr) As DWord
	Virtual Function UnlockVertexBuffer() As DWord
	Virtual Function LockIndexBuffer(flags As DWord, ppData As DWordPtr) As DWord
	Virtual Function UnlockIndexBuffer() As DWord
	Virtual Function LockAttributeBuffer(flags As DWord, ppData As DWordPtr) As DWord
	Virtual Function UnlockAttributeBuffer() As DWord

	Virtual Function GetTessSize(fTessLevel As Single, Adaptive As DWord, NumTriangles As DWordPtr, NumVertices As DWordPtr) As DWord
	Virtual Function GenerateAdjacency(Tolerance As Single) As DWord
	Virtual Function CloneMesh(Options As DWord, pDecl As *D3DVERTEXELEMENT9, pMesh As *ID3DXPatchMesh) As DWord
	Virtual Function Optimize(flags As DWord) As DWord
	Virtual Function SetDisplaceParam(pTexture As *IDirect3DBaseTexture9, MinFilter As D3DTEXTUREFILTERTYPE, MagFilter As D3DTEXTUREFILTERTYPE, MipFilter As D3DTEXTUREFILTERTYPE, Wrap As D3DTEXTUREADDRESS, dwLODBias As DWord) As DWord
	Virtual Function GetDisplaceParam(ppTexture As **IDirect3DBaseTexture9, pMinFilter As *D3DTEXTUREFILTERTYPE, pMagFilter As *D3DTEXTUREFILTERTYPE, pMipFilter As *D3DTEXTUREFILTERTYPE, pWrap As *D3DTEXTUREADDRESS, lpdwLODBias As DWordPtr) As DWord
	Virtual Function Tessellate(fTessLevel As Single, pMesh As *ID3DXMesh) As DWord
	Virtual Function TessellateAdaptive(pTrans As *D3DXVECTOR4, dwMaxTessLevel As DWord, dwMinTessLevel As DWord, pMesh As *ID3DXMesh) As DWord
End Class
TypeDef LPD3DXPATCHMESH = *ID3DXPatchMesh


'---------------
' ID3DXSkinInfo
'---------------

Class ID3DXSkinInfo
	Inherits IUnknown
Public
	'Specify the which vertices do each bones influence and by how much
	Virtual Function SetBoneInfluence(bone As DWord, numInfluences As DWord, vertices As DWordPtr, weights As SinglePtr) As DWord
	Virtual Function SetBoneVertexInfluence(boneNum As DWord, influenceNum As DWord, weight As Single) As DWord
	Virtual Function GetNumBoneInfluences(bone As DWord) As DWord
	Virtual Function GetBoneInfluence(bone As DWord, vertices As DWordPtr, weights As SinglePtr) As DWord
	Virtual Function GetBoneVertexInfluence(boneNum As DWord, influenceNum As DWord, pWeight As SinglePtr, pVertexNum As DWordPtr) As DWord
	Virtual Function GetMaxVertexInfluences(maxVertexInfluences As DWordPtr) As DWord
	Virtual Function GetNumBones() As DWord
	Virtual Function FindBoneVertexInfluenceIndex(boneNum As DWord, vertexNum As DWord, pInfluenceIndex As DWordPtr) As DWord

	'This gets the max face influences based on a triangle mesh with the specified index buffer
	Virtual Function GetMaxFaceInfluences(pIB As *IDirect3DIndexBuffer9, NumFaces As DWord, maxFaceInfluences As DWordPtr) As DWord

	'Set min bone influence. Bone influences that are smaller than this are ignored
	Virtual Function SetMinBoneInfluence(MinInfl As Single) As DWord
	'Get min bone influence. 
	Virtual Function GetMinBoneInfluence() As Single

	'Bone names are returned by D3DXLoadSkinMeshFromXof. They are not used by any other method of this object
	Virtual Function SetBoneName(Bone As DWord, pName As BytePtr) As DWord
	Virtual Function GetBoneName(Bone As DWord) As BytePtr

	'Bone offset matrices are returned by D3DXLoadSkinMeshFromXof. They are not used by any other method of this object
	Virtual Function SetBoneOffsetMatrix(Bone As DWord, pBoneTransform As *D3DXMATRIX) As DWord
	Virtual Function GetBoneOffsetMatrix(Bone As DWord) As *D3DXMATRIX

	'Clone a skin info object
	Virtual Function Clone(ppSkinInfo As **ID3DXSkinInfo) As DWord

	'Update bone influence information to match vertices after they are reordered. This should be called 
	'if the target vertex buffer has been reordered externally.
	Virtual Function Remap(NumVertices As DWord, pVertexRemap As DWordPtr) As DWord

	'These methods enable the modification of the vertex layout of the vertices that will be skinned
	Virtual Function SetFVF(FVF As DWord) As DWord
	Virtual Function SetDeclaration(pDeclaration As *D3DVERTEXELEMENT9) As DWord
	Virtual Function GetFVF() As DWord
	Virtual Function GetDeclaration(Declaration As *D3DVERTEXELEMENT9) As DWord

	'Apply SW skinning based on current pose matrices to the target vertices.
	Virtual Function UpdateSkinnedMesh(pBoneTransforms As *D3DXMATRIX, pBoneInvTransposeTransforms As *D3DXMATRIX, pVerticesSrc As VoidPtr, pVerticesDst As VoidPtr) As DWord

	'Takes a mesh and returns a new mesh with per vertex blend weights and a bone combination
	'table that describes which bones affect which subsets of the mesh
	Virtual Function ConvertToBlendedMesh(pMesh As *ID3DXMesh, Options As DWord, pAdjacencyIn As DWordPtr, pAdjacencyOut As DWordPtr, pFaceRemap As DWordPtr, ppVertexRemap As **ID3DXBuffer, pMaxFaceInfl As DWordPtr, pNumBoneCombinations As DWordPtr, ppBoneCombinationTable As **ID3DXBuffer, ppMesh As **ID3DXMesh) As DWord

	'Takes a mesh and returns a new mesh with per vertex blend weights and indices 
	'and a bone combination table that describes which bones palettes affect which subsets of the mesh
	Virtual Function ConvertToIndexedBlendedMesh(pMesh As *ID3DXMesh, Options As DWord, paletteSize As DWord, pAdjacencyIn As DWordPtr, pAdjacencyOut As DWordPtr, pFaceRemap As DWordPtr, ppVertexRemap As **ID3DXBuffer, pMaxVertexInfl As DWordPtr, pNumBoneCombinations As DWordPtr, ppBoneCombinationTable As **ID3DXBuffer, ppMesh As **ID3DXMesh) As DWord
End Class
TypeDef LPD3DXSKININFO = *ID3DXSkinInfo

