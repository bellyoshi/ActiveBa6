	Virtual Function ConvertPointRepsToAdjacency(pPRep As DWordPtr, pAdjacency As DWordPtr) As DWord
	Virtual Function ConvertAdjacencyToPointReps(pAdjacency As DWordPtr, pPRep As DWordPtr) As DWord
	Virtual Function GenerateAdjacency(Epsilon As Single, pAdjacency As DWordPtr) As DWord

	Virtual Function UpdateSemantics(Declaration As *D3DVERTEXELEMENT9) As DWord

    'ID3DXPMesh
	Virtual Function ClonePMeshFVF(Options As DWord, FVF As DWord, pD3DDevice As LPDIRECT3DDEVICE9, ppCloneMesh As **ID3DXMesh) As DWord
	Virtual Function ClonePMesh(Options As DWord, pDeclaration As *D3DVERTEXELEMENT9, pD3DDevice As LPDIRECT3DDEVICE9, ppCloneMesh As **ID3DXMesh) As DWord
