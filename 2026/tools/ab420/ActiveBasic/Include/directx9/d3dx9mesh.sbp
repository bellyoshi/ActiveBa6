	Virtual Function ConvertAdjacencyToPointReps(pAdjacency As DWordPtr, pPRep As DWordPtr) As DWord
	Virtual Function GenerateAdjacency(Epsilon As Single, pAdjacency As DWordPtr) As DWord

	Virtual Function UpdateSemantics(Declaration As *D3DVERTEXELEMENT9) As DWord

    'ID3DXMesh
	Virtual Function LockAttributeBuffer(Flags As DWord, ppData As VoidPtr) As DWord
	Virtual Function UnlockAttributeBuffer() As DWord
	Virtual Function Optimize(Flags As DWord, pAdjacencyIn As DWordPtr, pAdjacencyOut As DWordPtr, pFaceRemap As DWordPtr, ppVertexRemap As **ID3DXBuffer, ppOptMesh As **ID3DXMesh) As DWord
	Virtual Function OptimizeInplace(Flags As DWord, pAdjacencyIn As DWordPtr, pAdjacencyOut As DWordPtr, pFaceRemap As DWordPtr, ppVertexRemap As **ID3DXBuffer) As DWord
	Virtual Function SetAttributeTable(pAttribTable As *D3DXATTRIBUTERANGE, cAttribTableSize As DWord) As DWord
End Class
TypeDef LPD3DXMESH = *ID3DXMesh


Class ID3DXPMesh
	Inherits IUnknown
Public
    'ID3DXBaseMesh
	Virtual Function DrawSubset(AttribId As DWord) As DWord
